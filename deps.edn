{:paths ["src"]
 :deps {org.clojure/clojure {:mvn/version "1.12.1"}

        ;; hive-dsl — defadt (closed sum types) for WorkflowEvent ADT +
        ;; Result spec. Pinned ahead of the fleet (siblings at v0.5.1) for the
        ;; MALLI-P4-D5 spec<->malli convergence; see hive memory.
        io.github.hive-agi/hive-dsl
        {:git/tag "v0.5.2" :git/sha "8d9760c"}

        ;; metosin/malli — schema for the WorkflowAST node map.
        ;; Version mirrored from hive-mcp/hive-knowledge/hive-agent/hive-di
        ;; (all sibling hive-* libs converge on 0.20.1).
        metosin/malli {:mvn/version "0.20.1"}}

 :aliases
 {:dev  {:extra-paths ["dev" "test"]
         :extra-deps  {org.clojure/test.check {:mvn/version "1.1.1"}}}

  :test {:extra-paths ["test"]
         :extra-deps  {org.clojure/test.check {:mvn/version "1.1.1"}
                       io.github.cognitect-labs/test-runner
                       {:git/tag "v0.5.1" :git/sha "dfb30dd"}}
         :main-opts ["-m" "cognitect.test-runner"]
         :exec-fn cognitect.test-runner.api/test}

  :typed {:extra-paths ["dev-typed"]
          :extra-deps {org.typedclojure/typed.clj.checker {:mvn/version "1.4.0"}}}}}
